{
  "info": {
    "name": "Orde-X Auth API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Buyer Signup",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"buyer@example.com\",\n  \"password\": \"Password123!\",\n  \"firstName\": \"John\",\n  \"lastName\": \"Doe\"\n}"
        },
        "url": {
          "raw": "http://localhost:5000/api/v1/auth/signup/buyer",
          "protocol": "http",
          "host": [ "localhost" ],
          "port": "5000",
          "path": [ "api", "v1", "auth", "signup", "buyer" ]
        }
      }
    },
    {
      "name": "Supplier Signup",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"supplier@example.com\",\n  \"password\": \"Password123!\",\n  \"firstName\": \"Jane\",\n  \"lastName\": \"Smith\",\n  \"companyName\": \"Tech Supplies Co.\",\n  \"registrationNumber\": \"REG-12345\",\n  \"businessType\": \"MANUFACTURING\"\n}"
        },
        "url": {
          "raw": "http://localhost:5000/api/v1/auth/signup/supplier",
          "protocol": "http",
          "host": [ "localhost" ],
          "port": "5000",
          "path": [ "api", "v1", "auth", "signup", "supplier" ]
        }
      }
    },
    {
      "name": "Login",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"buyer@example.com\",\n  \"password\": \"Password123!\"\n}"
        },
        "url": {
          "raw": "http://localhost:5000/api/v1/auth/login",
          "protocol": "http",
          "host": [ "localhost" ],
          "port": "5000",
          "path": [ "api", "v1", "auth", "login" ]
        }
      }
    },
    {
      "name": "Verify Email",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "http://localhost:5000/api/v1/auth/verify-email?token=YOUR_JWT_TOKEN",
          "protocol": "http",
          "host": [ "localhost" ],
          "port": "5000",
          "path": [ "api", "v1", "auth", "verify-email" ],
          "query": [
            { "key": "token", "value": "YOUR_JWT_TOKEN" }
          ]
        }
      }
    },
    {
      "name": "Refresh Token",
      "request": {
        "method": "POST",
        "header": [],
        "url": {
          "raw": "http://localhost:5000/api/v1/auth/refresh-token",
          "protocol": "http",
          "host": [ "localhost" ],
          "port": "5000",
          "path": [ "api", "v1", "auth", "refresh-token" ]
        }
      }
    },
    {
      "name": "Forgot Password",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"buyer@example.com\"\n}"
        },
        "url": {
          "raw": "http://localhost:5000/api/v1/auth/forgot-password",
          "protocol": "http",
          "host": [ "localhost" ],
          "port": "5000",
          "path": [ "api", "v1", "auth", "forgot-password" ]
        }
      }
    },
    {
      "name": "Verify Supplier (Admin)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer YOUR_ADMIN_TOKEN" }
        ],
        "url": {
          "raw": "http://localhost:5000/api/v1/auth/verify-supplier/SUPPLIER_ID_HERE",
          "protocol": "http",
          "host": [ "localhost" ],
          "port": "5000",
          "path": [ "api", "v1", "auth", "verify-supplier", "SUPPLIER_ID_HERE" ]
        }
      }
    }
  ]
}
