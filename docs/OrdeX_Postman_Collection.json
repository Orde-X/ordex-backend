{
  "info": {
    "name": "Orde-X B2B Marketplace API",
    "description": "API Collection for the Orde-X B2B Marketplace Backend. Includes Auth, RFQs, Quotes, Products, and Suppliers.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000/api",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "1. Authentication",
      "item": [
        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"buyer@example.com\",\n  \"password\": \"securepassword123\",\n  \"role\": \"BUYER\",\n  \"name\": \"John Doe\",\n  \"companyName\": \"Global Sourcing Inc.\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/auth/register", "host": ["{{baseUrl}}"], "path": ["auth", "register"] }
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"buyer@example.com\",\n  \"password\": \"securepassword123\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth", "login"] }
          }
        },
        {
          "name": "Get Current Profile (Me)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{baseUrl}}/auth/me", "host": ["{{baseUrl}}"], "path": ["auth", "me"] }
          }
        }
      ]
    },
    {
      "name": "2. Request For Quotation (RFQ)",
      "item": [
        {
          "name": "Create RFQ",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"productName\": \"Industrial Water Pump\",\n  \"category\": \"machinery\",\n  \"quantity\": 500,\n  \"unit\": \"pieces\",\n  \"specifications\": \"Stainless Steel, 220V\",\n  \"timeline\": \"urgent\",\n  \"budget\": \"$5,000 - $10,000\",\n  \"requireCertifications\": true\n}"
            },
            "url": { "raw": "{{baseUrl}}/rfqs", "host": ["{{baseUrl}}"], "path": ["rfqs"] }
          }
        },
        {
          "name": "List RFQs",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{baseUrl}}/rfqs", "host": ["{{baseUrl}}"], "path": ["rfqs"] }
          }
        }
      ]
    },
    {
      "name": "3. Quotes",
      "item": [
        {
          "name": "Submit Quote (Supplier)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"price\": 4500,\n  \"deliveryTime\": \"5 days\",\n  \"terms\": \"50% advance, 50% on delivery\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/rfqs/:id/quotes", "host": ["{{baseUrl}}"], "path": ["rfqs", ":id", "quotes"], "variable": [{"key": "id", "value": "1"}] }
          }
        }
      ]
    },
    {
      "name": "4. Products & Catalog",
      "item": [
        {
          "name": "List Products",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/products?category=machinery", "host": ["{{baseUrl}}"], "path": ["products"], "query": [{"key": "category", "value": "machinery"}] }
          }
        }
      ]
    }
  ]
}
